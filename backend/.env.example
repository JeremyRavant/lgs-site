# Exemple de configuration du backend Express

# Environnement (development ou production)
NODE_ENV=development

# Port sur lequel ton serveur écoute
PORT=3000

# URL de ta base MongoDB (ne pas mettre ton vrai mot de passe ici)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/nom_de_ta_db

# Clé secrète pour signer les tokens JWT
JWT_SECRET=change-me-to-a-long-random-string

# URL autorisées par CORS
CORS_ORIGINS=https://tondomaine.fr,https://www.tondomaine.fr

# Clé API (si tu utilises un service externe)
GOOGLE_API_KEY=your_google_key_here
